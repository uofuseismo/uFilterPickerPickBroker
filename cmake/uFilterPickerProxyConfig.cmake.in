#.rst
# FinduFilterPickerProxy
# ----------------------
#
# Finds the UUSS filter picker proxy library.
#
# Imported Targets
# ^^^^^^^^^^^^^^^^
#
# ``uFilterPickerProxy_FOUND``
#   True indicates uFilterPickerProxy was found.
# ``uFilterPickerProxy::uFilterPickerProxy``
#   The filter picker proxy library, if found.
include(CMakeFindDependencyMacro)

find_dependency(TBB)

@PACKAGE_INIT@

include("${CMAKE_CURRENT_LIST_DIR}/@PROJECT_NAME@Targets.cmake")
